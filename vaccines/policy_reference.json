{
    "vaccines": [
        {
            "name": "Penta",
            "live": false,
            "display_name": "Pentavalent (DTP + HBV + Hib)",
            "protects_against": "Diphtheria, Tetanus, Pertussis, Hepatitis B, Hib",
            "clinical_notes": "Covers HB series doses 2-4 for infants under 12 months. Do not use as standalone HB for children over 1 year."
        },
        {
            "name": "DTC",
            "live": false,
            "display_name": "Diphtheria, Tetanus, Pertussis",
            "protects_against": "Diphtheria, Tetanus, Pertussis",
            "clinical_notes": "For children 3-7 years old."
        },
        {
            "name": "Td",
            "live": false,
            "display_name": "Tetanus, Diphtheria",
            "protects_against": "Tetanus, Diphtheria",
            "clinical_notes": "For children over 7 years old."
        },
        {
            "name": "RR",
            "live": true,
            "compatible_with": [
                "VPO"
            ],
            "display_name": "Measles, Rubella",
            "protects_against": "Measles, Rubella",
            "clinical_notes": "Routine live vaccine. First dose at 9 months."
        },
        {
            "name": "BCG",
            "live": true,
            "compatible_with": [
                "VPO"
            ],
            "display_name": "Bacille Calmette-Guérin",
            "protects_against": "Tuberculosis",
            "clinical_notes": "Birth dose. Use 0.05ml for infants under 1 year, 0.1ml for children over 1 year."
        },
        {
            "name": "Prevenar13",
            "live": false,
            "manufacturer": "Pfizer",
            "display_name": "Pneumococcal Conjugate (PREVNAR13)",
            "protects_against": "Pneumococcal disease (13 strains)",
            "clinical_notes": "Primary infant PCV track."
        },
        {
            "name": "Primovax",
            "live": false,
            "manufacturer": "Acme",
            "display_name": "Pneumococcal conjugate (PRIMOVAX13)",
            "protects_against": "Pneumococcal disease (13 strains)",
            "clinical_notes": "Alternative PCV track starting at dose 2. Requires 14d interval from DTP doses."
        },
        {
            "name": "Rotasil",
            "live": true,
            "compatible_with": [
                "VPO"
            ],
            "display_name": "Rotavirus (Rotasil)",
            "protects_against": "Rotavirus",
            "clinical_notes": "Oral live vaccine. Only valid for children under 2 years old."
        },
        {
            "name": "VPO",
            "live": true,
            "compatible_with": [
                "BCG",
                "Rotasil",
                "RR"
            ],
            "display_name": "Oral Poliovirus",
            "protects_against": "Polio",
            "clinical_notes": "Oral live vaccine. Birth dose VPO 0 must be given with BCG."
        },
        {
            "name": "HB",
            "live": false,
            "display_name": "Hepatitis B (standalone)",
            "protects_against": "Hepatitis B",
            "clinical_notes": "HB0 birth dose. Standalone doses for catch-up are only valid for children over 12 months."
        },
        {
            "name": "VPI",
            "live": false,
            "display_name": "Inactivated Poliovirus",
            "protects_against": "Polio",
            "clinical_notes": "Injectable polio vaccine."
        }
    ],
